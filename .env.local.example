# TravelMate environment variables
# Put secrets in Vercel Environment Variables, not inside frontend React code.

# Clerk authentication for React + Vite. Publishable key only; never use CLERK_SECRET_KEY in frontend code.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here

# Flight API: Aviationstack free/demo key
# User-provided key can be used here locally and in Vercel; do not prefix with VITE_ because it must stay server-side.
AVIATIONSTACK_API_KEY=your_aviationstack_key_here
AVIATIONSTACK_BASE_URL=https://api.aviationstack.com/v1

# Train API: RapidAPI IRCTC / irctc1
# This single RapidAPI key powers live status, PNR, train search, station search,
# trains between stations, trains by station, live station, and seat availability.
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_TRAIN_HOST=irctc1.p.rapidapi.com
IRCTC_API_BASE_URL=https://irctc1.p.rapidapi.com
TRAIN_API_PROVIDER=rapidapi-irctc1

# Bus API: fallback for hackathon unless partner API is approved
BUS_API_PROVIDER=fallback
BUS_API_URL=
BUS_API_KEY=

# Optional voice assistant backend
ANTHROPIC_API_KEY=your_anthropic_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6
